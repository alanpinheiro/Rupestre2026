@model Rupestre.Application.DTOs.DashboardDto
@{
    ViewData["Title"] = "Dashboard";
    var fmtBRL = (decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Dashboard</h4>
    <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@DateTime.Today.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))</span>
</div>

<!-- ─── Cards rápidos ─────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-currency-dollar text-primary fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Vendas de Hoje</div>
                    <div class="fw-bold fs-5">@fmtBRL(Model.VendasHoje)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-truck text-warning fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Móveis a Entregar</div>
                    <div class="fw-bold fs-5">@Model.MoveisAEntregar</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-success bg-opacity-10 p-3">
                    <i class="bi bi-tools text-success fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Montagens para Hoje</div>
                    <div class="fw-bold fs-5">@Model.MontagensParaHoje</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ─── Top 10 Produtos ───────────────────────────────────────── -->
<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white fw-semibold">
                <i class="bi bi-trophy me-2"></i>Top 10 Produtos por Faturamento
            </div>
            <div class="card-body">
                <canvas id="chartAbc" height="110"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white fw-semibold">
                <i class="bi bi-boxes me-2"></i>Estoque Atual
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produto</th>
                            <th class="text-center" style="width:80px">Estoque</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.AbcLabels.Count; i++)
                        {
                            var estoque = Model.AbcEstoques[i];
                            var badgeClass = estoque <= 0 ? "danger" : estoque <= 3 ? "warning text-dark" : "success";
                            <tr>
                                <td class="text-truncate" style="max-width:160px" title="@Model.AbcLabels[i]">@Model.AbcLabels[i]</td>
                                <td class="text-center">
                                    <span class="badge bg-@badgeClass">@estoque</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ─── Faturamento vs Recebimento ────────────────────────────── -->
<div class="row g-3">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-semibold">
                <i class="bi bi-bar-chart-grouped me-2"></i>Faturamento vs. Recebimento (últimos 6 meses)
            </div>
            <div class="card-body">
                <canvas id="chartFaturamento" height="80"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chart.js/chart.umd.min.js"></script>
<script>
const faturamentoLabels = @Json.Serialize(Model.FaturamentoLabels);
const faturamentoSeries = @Json.Serialize(Model.FaturamentoSeries);
const recebimentoSeries = @Json.Serialize(Model.RecebimentoSeries);
const abcLabels         = @Json.Serialize(Model.AbcLabels);
const abcSeries         = @Json.Serialize(Model.AbcSeries);

Chart.defaults.font.family = 'inherit';
Chart.defaults.color = '#6c757d';

// ── Top 10 Produtos ────────────────────────────────────────────
new Chart(document.getElementById('chartAbc'), {
    type: 'bar',
    data: {
        labels: abcLabels,
        datasets: [{
            label: 'Qtd Vendida',
            data: abcSeries,
            backgroundColor: 'rgba(111,66,193,0.75)',
            borderRadius: 4
        }]
    },
    options: {
        responsive: true,
        indexAxis: 'y',
        plugins: {
            legend: { display: false },
            tooltip: {
                callbacks: {
                    label: ctx => ' ' + ctx.parsed.x + ' unid.'
                }
            }
        },
        scales: {
            x: {
                ticks: { stepSize: 1 }
            }
        }
    }
});

// ── Faturamento vs Recebimento ─────────────────────────────────
new Chart(document.getElementById('chartFaturamento'), {
    type: 'bar',
    data: {
        labels: faturamentoLabels,
        datasets: [
            {
                label: 'Faturamento',
                data: faturamentoSeries,
                backgroundColor: 'rgba(13,110,253,0.75)',
                borderRadius: 4
            },
            {
                label: 'Recebimento',
                data: recebimentoSeries,
                backgroundColor: 'rgba(25,135,84,0.75)',
                borderRadius: 4
            }
        ]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { position: 'top' },
            tooltip: {
                callbacks: {
                    label: ctx => ' R$ ' + ctx.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
                }
            }
        },
        scales: {
            y: {
                ticks: {
                    callback: v => 'R$ ' + v.toLocaleString('pt-BR', { minimumFractionDigits: 0 })
                }
            }
        }
    }
});
</script>
}
