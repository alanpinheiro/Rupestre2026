@{
    ViewData["Title"] = "Vendas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Vendas</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> Nova Venda
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table id="tblVendas" class="table table-striped table-bordered table-hover w-100">
            <thead class="table-light">
                <tr>
                    <th class="text-center">#</th>
                    <th>Data</th>
                    <th>Pedido</th>
                    <th>Cliente</th>
                    <th>Vendedor</th>
                    <th class="text-end">Total</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Entrega</th>
                    <th class="text-center" style="width:100px">Ações</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const statusVendaLabel = { 0: 'Cancelada', 1: 'Concluída', 2: 'Pendente' };
    const statusVendaBadge = { 0: 'danger', 1: 'success', 2: 'warning text-dark' };
    const statusEntregaLabel = { 1: 'Entregue', 2: 'Agendada', 3: 'Atrasada' };
    const statusEntregaBadge = { 1: 'success', 2: 'info text-dark', 3: 'danger' };

    const table = $('#tblVendas').DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/2.3.4/i18n/pt-BR.json' },
        pageLength: 10,
        lengthMenu: [[10, 25, 50], [10, 25, 50]],
        processing: true,
        serverSide: true,
        order: [[1, 'desc']],
        ajax: { url: '@Url.Action("GetData")', type: 'POST' },
        columns: [
            { data: 'id', className: 'text-center' },
            { data: 'dataVenda', render: v => new Date(v).toLocaleDateString('pt-BR') },
            { data: 'numeroPedidoExterno', defaultContent: '-' },
            { data: 'nomeCliente' },
            { data: 'nomeVendedor' },
            {
                data: 'totalVenda', className: 'text-end',
                render: v => 'R$ ' + (v ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 })
            },
            {
                data: 'statusVenda', className: 'text-center',
                render: v => `<span class="badge bg-${statusVendaBadge[v] ?? 'secondary'}">${statusVendaLabel[v] ?? v}</span>`
            },
            {
                data: 'statusEntrega', className: 'text-center',
                render: v => `<span class="badge bg-${statusEntregaBadge[v] ?? 'secondary'}">${statusEntregaLabel[v] ?? v}</span>`
            },
            {
                data: 'id', orderable: false, searchable: false, className: 'text-center',
                render: id => `
                    <a href="@Url.Action("Edit")/${id}" class="btn btn-sm btn-outline-primary" title="Editar"><i class="bi bi-pencil"></i></a>
                    <button class="btn btn-sm btn-outline-danger btn-delete" data-id="${id}" title="Excluir"><i class="bi bi-trash"></i></button>`
            }
        ]
    });

    $(document).on('click', '.btn-delete', function () {
        if (!confirm('Deseja excluir esta venda?')) return;
        $.post('@Url.Action("Delete")/' + $(this).data('id'), function (res) {
            if (res.success) table.ajax.reload();
            else alert(res.message);
        });
    });
</script>
}
