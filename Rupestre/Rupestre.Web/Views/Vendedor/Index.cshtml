@{
    ViewData["Title"] = "Vendedores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Vendedores</h4>
    <button class="btn btn-primary btn-sm" id="btnNovo">
        <i class="bi bi-plus-lg"></i> Novo Vendedor
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table id="tblVendedores" class="table table-striped table-bordered table-hover w-100">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th class="text-center" style="width:120px">Ações</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<div class="modal fade" id="entityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Vendedor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const modal = new bootstrap.Modal(document.getElementById('entityModal'));

    const table = $('#tblVendedores').DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/2.3.4/i18n/pt-BR.json' },
        pageLength: 10,
        lengthMenu: [[10, 25, 50], [10, 25, 50]],
        processing: true,
        serverSide: true,
        ajax: { url: '@Url.Action("GetData")', type: 'POST' },
        columns: [
            { data: 'nome' },
            {
                data: 'id', orderable: false, searchable: false, className: 'text-center',
                render: id => `
                    <button class="btn btn-sm btn-outline-primary btn-edit" data-id="${id}" title="Editar"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-sm btn-outline-danger btn-delete" data-id="${id}" title="Excluir"><i class="bi bi-trash"></i></button>`
            }
        ]
    });

    $('#btnNovo').on('click', function () {
        $('#modalTitle').text('Novo Vendedor');
        $.get('@Url.Action("Form")', function (html) { $('#modalBody').html(html); modal.show(); });
    });

    $(document).on('click', '.btn-edit', function () {
        $('#modalTitle').text('Editar Vendedor');
        $.get('@Url.Action("Form")/' + $(this).data('id'), function (html) { $('#modalBody').html(html); modal.show(); });
    });

    $(document).on('submit', '#formEntity', function (e) {
        e.preventDefault();
        $.post($(this).attr('action'), $(this).serialize(), function (res) {
            if (res.success) { modal.hide(); table.ajax.reload(); }
            else showAlert(res.message);
        });
    });

    $(document).on('click', '.btn-delete', function () {
        const id = $(this).data('id');
        showConfirm('Deseja excluir este vendedor?', function () {
            $.post('@Url.Action("Delete")/' + id, function (res) {
                if (res.success) table.ajax.reload();
                else showAlert(res.message);
            });
        });
    });
</script>
}
