<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rupestre</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="d-flex" id="appWrapper">

    <!-- ─── Sidebar ──────────────────────────────────────────── -->
    <nav id="sidebar" class="bg-dark d-flex flex-column">
        <div class="sidebar-brand px-3 py-3 border-bottom border-secondary">
            <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none fw-bold">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 32 32" class="me-2" style="vertical-align:-.2em">
                    <rect x="4" y="18" width="24" height="5" rx="1.5"/>
                    <rect x="2" y="13" width="5" height="10" rx="1.5"/>
                    <rect x="25" y="13" width="5" height="10" rx="1.5"/>
                    <rect x="7" y="9" width="18" height="9" rx="1.5"/>
                    <rect x="8" y="23" width="3" height="4" rx="1"/>
                    <rect x="21" y="23" width="3" height="4" rx="1"/>
                </svg>Rupestre
            </a>
        </div>

        <ul class="nav flex-column flex-grow-1 pt-2 pb-3">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house me-2"></i>Início
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Caixa" asp-action="Index">
                    <i class="bi bi-cash-coin me-2"></i>Caixa
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Venda" asp-action="Index">
                    <i class="bi bi-cart3 me-2"></i>Vendas
                </a>
            </li>
            @if (User.IsInRole("Gerente"))
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="VendaRemessa" asp-action="Index">
                        <i class="bi bi-send me-2"></i>Remessas
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Suprimento" asp-action="Index">
                        <i class="bi bi-box-arrow-in-down me-2"></i>Suprimentos
                    </a>
                </li>
            }
            <li class="nav-item">
                <a class="nav-link" asp-controller="Despesa" asp-action="Index">
                    <i class="bi bi-receipt me-2"></i>Despesas
                </a>
            </li>

            @if (User.IsInRole("Gerente"))
            {
                <li><hr class="border-secondary mx-3 my-2" /></li>

                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center" data-bs-toggle="collapse"
                       href="#cadastrosMenu" role="button" aria-expanded="false">
                        <i class="bi bi-grid me-2"></i>
                        <span class="flex-grow-1">Cadastros</span>
                        <i class="bi bi-chevron-down small" id="cadastrosChevron"></i>
                    </a>
                    <div class="collapse" id="cadastrosMenu">
                        <ul class="nav flex-column sidebar-submenu">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cliente" asp-action="Index">
                                    <i class="bi bi-person me-2"></i>Clientes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Fabricante" asp-action="Index">
                                    <i class="bi bi-building me-2"></i>Fabricantes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Produto" asp-action="Index">
                                    <i class="bi bi-box-seam me-2"></i>Produtos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Vendedor" asp-action="Index">
                                    <i class="bi bi-person-badge me-2"></i>Vendedores
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="FormaPagamento" asp-action="Index">
                                    <i class="bi bi-credit-card me-2"></i>Formas de Pagamento
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuario" asp-action="Index">
                                    <i class="bi bi-people me-2"></i>Usuários
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
            }
        </ul>

        <div class="px-3 pb-3 border-top border-secondary pt-3">
            <div class="text-muted small mb-2 px-1">
                <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
            </div>
            <form method="post" asp-controller="Login" asp-action="Sair">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-secondary w-100 text-start">
                    <i class="bi bi-box-arrow-left me-2"></i>Sair
                </button>
            </form>
        </div>
    </nav>

    <!-- ─── Overlay mobile ───────────────────────────────────── -->
    <div id="sidebarOverlay"></div>

    <!-- ─── Conteúdo ─────────────────────────────────────────── -->
    <div class="d-flex flex-column flex-grow-1" id="contentWrapper">

        <!-- Topbar mobile -->
        <header class="bg-dark d-flex d-md-none align-items-center px-3 py-2">
            <button class="btn btn-sm text-white p-1 me-2" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <span class="text-white fw-bold">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 32 32" class="me-1" style="vertical-align:-.2em">
                    <rect x="4" y="18" width="24" height="5" rx="1.5"/>
                    <rect x="2" y="13" width="5" height="10" rx="1.5"/>
                    <rect x="25" y="13" width="5" height="10" rx="1.5"/>
                    <rect x="7" y="9" width="18" height="9" rx="1.5"/>
                    <rect x="8" y="23" width="3" height="4" rx="1"/>
                    <rect x="21" y="23" width="3" height="4" rx="1"/>
                </svg>Rupestre
            </span>
        </header>

        <div class="container-fluid px-4 py-3 flex-grow-1">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/datatables/dataTables.min.js"></script>
<script src="~/lib/datatables/dataTables.bootstrap5.min.js"></script>
<script src="~/lib/select2/js/select2.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
    // Destaca o link ativo com base na URL atual
    (function () {
        const path = window.location.pathname.toLowerCase();
        document.querySelectorAll('#sidebar .nav-link[href]').forEach(function (a) {
            const href = a.getAttribute('href').toLowerCase();
            if (href === '/') {
                if (path === '/') a.classList.add('active');
            } else if (path.startsWith(href)) {
                a.classList.add('active');
                const collapse = a.closest('.collapse');
                if (collapse) {
                    bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false }).show();
                }
            }
        });
    })();

    // Gira o chevron ao abrir/fechar Cadastros
    (function () {
        const menu = document.getElementById('cadastrosMenu');
        const chevron = document.getElementById('cadastrosChevron');
        if (menu && chevron) {
            menu.addEventListener('show.bs.collapse', function () { chevron.style.transform = 'rotate(180deg)'; });
            menu.addEventListener('hide.bs.collapse', function () { chevron.style.transform = ''; });
        }
    })();

    // Toggle sidebar no mobile
    (function () {
        const toggle = document.getElementById('sidebarToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (toggle) {
            toggle.addEventListener('click', function () {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            });
            overlay.addEventListener('click', function () {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            });
        }
    })();
</script>
</body>
</html>
