<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rupestre</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-gem"></i> Rupestre
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Início
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Caixa" asp-action="Index">
                                <i class="bi bi-cash-coin"></i> Caixa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Venda" asp-action="Index">
                                <i class="bi bi-cart3"></i> Vendas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="VendaRemessa" asp-action="Index">
                                <i class="bi bi-send"></i> Remessas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Suprimento" asp-action="Index">
                                <i class="bi bi-box-arrow-in-down"></i> Suprimentos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Despesa" asp-action="Index">
                                <i class="bi bi-receipt"></i> Despesas
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-people"></i> Cadastros
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Cliente" asp-action="Index">
                                        <i class="bi bi-person"></i> Clientes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Fabricante" asp-action="Index">
                                        <i class="bi bi-building"></i> Fabricantes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Produto" asp-action="Index">
                                        <i class="bi bi-box-seam"></i> Produtos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Vendedor" asp-action="Index">
                                        <i class="bi bi-person-badge"></i> Vendedores
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="FormaPagamento" asp-action="Index">
                                        <i class="bi bi-credit-card"></i> Formas de Pagamento
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

 @*    <footer class="border-top footer text-muted mt-4">
        <div class="container-fluid px-4 py-2">
            &copy; @DateTime.Now.Year - Rupestre
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/datatables/dataTables.min.js"></script>
    <script src="~/lib/datatables/dataTables.bootstrap5.min.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
