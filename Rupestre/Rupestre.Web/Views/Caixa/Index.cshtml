@model Rupestre.Application.DTOs.CaixaDto?
@{
    ViewData["Title"] = "Caixa";
    bool aberto = Model is not null;
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <div class="d-flex align-items-center mb-4">
            <h4 class="mb-0 me-3">Caixa</h4>
            @if (aberto)
            {
                <span class="badge bg-success fs-6 px-3 py-2">
                    <i class="bi bi-circle-fill me-1" style="font-size:.6rem"></i> Aberto
                </span>
            }
            else
            {
                <span class="badge bg-secondary fs-6 px-3 py-2">
                    <i class="bi bi-circle me-1" style="font-size:.6rem"></i> Fechado
                </span>
            }
        </div>

        @if (TempData["Sucesso"] is string sucesso)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@sucesso
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Erro"] is string erro)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@erro
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (aberto)
        {
            <!-- Caixa aberto: exibe informações -->
            <div class="card border-success shadow-sm">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-cash-coin me-2"></i>Caixa em Andamento
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Data de Abertura</dt>
                        <dd class="col-sm-7 fw-semibold">@Model!.DataAbertura.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-5 text-muted">Valor de Abertura</dt>
                        <dd class="col-sm-7 fw-semibold">@Model.ValorAbertura.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</dd>

                        <dt class="col-sm-5 text-muted">Dinheiro no Caixa</dt>
                        <dd class="col-sm-7 fw-semibold text-success fs-5">
                            @((Model.DinheiroNoCaixa ?? 0).ToString("C", new System.Globalization.CultureInfo("pt-BR")))
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-transparent text-end">
                    <form asp-action="Fechar" method="post" id="formFechar">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model!.Id" />
                        <button type="button" class="btn btn-danger" id="btnFecharCaixa">
                            <i class="bi bi-lock me-1"></i> Fechar Caixa
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <!-- Caixa fechado: formulário de abertura -->
            <div class="card border-secondary shadow-sm">
                <div class="card-header bg-light">
                    <i class="bi bi-unlock me-2"></i>Abertura de Caixa
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">
                        Nenhum caixa está aberto. Informe o valor inicial para abrir o caixa do dia.
                    </p>

                    <form asp-action="Abrir" method="post" id="formAbrirCaixa">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="valorAbertura" name="valorAbertura" value="0" />
                        <div class="mb-4">
                            <label for="valorAberturaDisplay" class="form-label fw-semibold">
                                Valor de Abertura <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">R$</span>
                                <input type="text" id="valorAberturaDisplay"
                                       class="form-control" inputmode="numeric"
                                       value="0,00" required autofocus autocomplete="off" />
                            </div>
                            <div class="form-text">Informe o troco inicial disponível no caixa.</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-unlock me-2"></i>Abrir Caixa
                            </button>
                        </div>
                    </form>

                    <script>
                        (function () {
                            const display = document.getElementById('valorAberturaDisplay');
                            const hidden = document.getElementById('valorAbertura');

                            function formatCurrency(cents) {
                                const str = String(cents).padStart(3, '0');
                                const reais = str.slice(0, -2).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
                                return reais + ',' + str.slice(-2);
                            }

                            display.addEventListener('input', function () {
                                const digits = this.value.replace(/\D/g, '');
                                const cents = parseInt(digits || '0', 10);
                                this.value = formatCurrency(cents);
                                hidden.value = (cents / 100).toFixed(2).replace('.', '.');
                            });

                            display.addEventListener('keydown', function (e) {
                                if (e.key === 'Backspace') {
                                    e.preventDefault();
                                    const digits = this.value.replace(/\D/g, '');
                                    const cents = Math.floor(parseInt(digits || '0', 10) / 10);
                                    this.value = formatCurrency(cents);
                                    hidden.value = (cents / 100).toFixed(2);
                                }
                            });

                            document.getElementById('formAbrirCaixa').addEventListener('submit', function () {
                                const digits = display.value.replace(/\D/g, '');
                                hidden.value = (parseInt(digits || '0', 10) / 100).toFixed(2);
                            });
                        })();
                    </script>
                </div>
                <div class="card-footer bg-transparent text-muted small">
                    <i class="bi bi-calendar me-1"></i>
                    Data: @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
    const btnFechar = document.getElementById('btnFecharCaixa');
    if (btnFechar) {
        btnFechar.addEventListener('click', function () {
            showConfirm('Confirma o fechamento do caixa?', function () {
                document.getElementById('formFechar').submit();
            });
        });
    }
</script>
}
