@model List<Rupestre.Web.ViewModels.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Usuários</h4>
    <button class="btn btn-primary btn-sm" id="btnNovo">
        <i class="bi bi-plus-lg"></i> Novo Usuário
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Login</th>
                    <th>Nome</th>
                    <th class="text-center">Perfil</th>
                    <th class="text-center" style="width:110px">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.UserName</td>
                        <td>@u.NomeCompleto</td>
                        <td class="text-center">
                            <span class="badge @(u.Perfil == "Gerente" ? "bg-primary" : "bg-secondary")">
                                @u.Perfil
                            </span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary btn-edit"
                                    data-id="@u.Id" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-delete"
                                    data-id="@u.Id" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="entityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content"></div>
    </div>
</div>

@section Scripts {
<script>
    const modal = new bootstrap.Modal(document.getElementById('entityModal'));

    function openForm(id) {
        const url = id ? '@Url.Action("Form")/' + id : '@Url.Action("Form")';
        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.querySelector('#entityModal .modal-content').innerHTML = html;
                modal.show();
            });
    }

    document.getElementById('btnNovo').addEventListener('click', () => openForm(null));

    $(document).on('click', '.btn-edit', function () {
        openForm($(this).data('id'));
    });

    $(document).on('click', '.btn-delete', function () {
        const id = $(this).data('id');
        showConfirm('Deseja excluir este usuário?', function () {
            $.post('@Url.Action("Delete")/' + id, function (res) {
                if (res.success) location.reload();
                else showAlert(res.message);
            });
        });
    });

    $(document).on('submit', '#formEntity', function (e) {
        e.preventDefault();
        $.post('@Url.Action("Save")', $(this).serialize(), function (res) {
            if (res.success) { modal.hide(); location.reload(); }
            else showAlert(res.message);
        });
    });
</script>
}
