@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rupestre — Entrar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #1a1a2e;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
        }

        /* ── Painel esquerdo ── */
        .panel-brand {
            width: 45%;
            background: linear-gradient(145deg, #1e1e2e 0%, #2d2d44 60%, #3a3a55 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        .panel-brand::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: rgba(255,255,255,0.03);
            top: -100px;
            left: -100px;
        }

        .panel-brand::after {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,0.03);
            bottom: -80px;
            right: -60px;
        }

        .brand-icon {
            width: 90px;
            height: 90px;
            background: rgba(255,255,255,0.08);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .brand-name {
            font-size: 2.2rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.04em;
            margin-bottom: 0.5rem;
        }

        .brand-sub {
            font-size: 0.95rem;
            color: rgba(255,255,255,0.45);
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .brand-divider {
            width: 40px;
            height: 2px;
            background: rgba(255,255,255,0.2);
            margin: 1.8rem auto;
        }

        .brand-features {
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: left;
            width: 100%;
            max-width: 260px;
        }

        .brand-features li {
            color: rgba(255,255,255,0.5);
            font-size: 0.85rem;
            padding: 0.4rem 0;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .brand-features li i {
            color: rgba(255,255,255,0.25);
            font-size: 0.8rem;
        }

        /* ── Painel direito ── */
        .panel-form {
            flex: 1;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
        }

        .form-card {
            width: 100%;
            max-width: 400px;
        }

        .form-card h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 0.35rem;
        }

        .form-card p.subtitle {
            color: #6c757d;
            font-size: 0.9rem;
            margin-bottom: 2.2rem;
        }

        .form-floating label {
            color: #888;
            font-size: 0.9rem;
        }

        .form-floating .form-control {
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            background: #fff;
            height: 56px;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-floating .form-control:focus {
            border-color: #3d3d5c;
            box-shadow: 0 0 0 3px rgba(61,61,92,0.12);
        }

        .btn-login {
            width: 100%;
            height: 52px;
            background: #2d2d44;
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            transition: background 0.2s, transform 0.1s;
        }

        .btn-login:hover {
            background: #3a3a55;
            color: #fff;
        }

        .btn-login:active {
            transform: scale(0.98);
        }

        .alert-erro {
            background: #fff0f0;
            border: 1px solid #f5c2c7;
            color: #842029;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .input-icon-wrap {
            position: relative;
        }

        .input-icon-wrap .bi {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
            font-size: 1rem;
            pointer-events: none;
            z-index: 10;
        }

        /* ── Mobile ── */
        @@media (max-width: 767.98px) {
            .panel-brand { display: none; }
            .panel-form  { background: #1a1a2e; }
            .form-card h2 { color: #fff; }
            .form-card p.subtitle { color: rgba(255,255,255,0.5); }
            .form-floating .form-control { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.15); color: #fff; }
            .form-floating .form-control:focus { border-color: rgba(255,255,255,0.4); box-shadow: none; }
            .form-floating label { color: rgba(255,255,255,0.45); }
        }
    </style>
</head>
<body>
<div class="login-wrapper">

    <!-- ── Painel esquerdo (marca) ─────────────────────────── -->
    <div class="panel-brand">
        <div class="brand-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" fill="rgba(255,255,255,0.85)" viewBox="0 0 32 32">
                <rect x="4" y="18" width="24" height="5" rx="1.5"/>
                <rect x="2" y="13" width="5" height="10" rx="1.5"/>
                <rect x="25" y="13" width="5" height="10" rx="1.5"/>
                <rect x="7" y="9" width="18" height="9" rx="1.5"/>
                <rect x="8" y="23" width="3" height="4" rx="1"/>
                <rect x="21" y="23" width="3" height="4" rx="1"/>
            </svg>
        </div>
        <div class="brand-name">Rupestre</div>
        <div class="brand-sub">Sistema de Gestão</div>
        <div class="brand-divider"></div>
        <ul class="brand-features">
            <li><i class="bi bi-check2-circle"></i> Controle de vendas e caixa</li>
            <li><i class="bi bi-check2-circle"></i> Gestão de produtos e estoque</li>
            <li><i class="bi bi-check2-circle"></i> Entregas e montagens</li>
            <li><i class="bi bi-check2-circle"></i> Relatórios e dashboard</li>
        </ul>
    </div>

    <!-- ── Painel direito (formulário) ─────────────────────── -->
    <div class="panel-form">
        <div class="form-card">
            <h2>Bem-vindo de volta</h2>
            <p class="subtitle">Entre com suas credenciais para acessar o sistema.</p>

            @if (ViewBag.Erro is string erro)
            {
                <div class="alert-erro">
                    <i class="bi bi-exclamation-circle-fill"></i> @erro
                </div>
            }

            <form method="post" asp-action="Index" asp-controller="Login">
                @Html.AntiForgeryToken()

                <div class="form-floating mb-3 input-icon-wrap">
                    <input type="text" class="form-control" id="usuario" name="usuario"
                           placeholder="Usuário" required autofocus autocomplete="username" />
                    <label for="usuario">Usuário</label>
                    <i class="bi bi-person"></i>
                </div>

                <div class="form-floating mb-4 input-icon-wrap">
                    <input type="password" class="form-control" id="senha" name="senha"
                           placeholder="Senha" required autocomplete="current-password" />
                    <label for="senha">Senha</label>
                    <i class="bi bi-lock"></i>
                </div>

                <button type="submit" class="btn btn-login">
                    Entrar
                </button>
            </form>

            <p class="text-center text-muted mt-4 mb-0" style="font-size:.78rem">
                &copy; @DateTime.Now.Year Rupestre — Todos os direitos reservados
            </p>
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
